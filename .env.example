# suitz — environment variables
# Everything runs on public defaults; copy to .env.local and override as needed.
#   cp .env.example .env.local

# Sepolia RPC endpoint. A keyed provider (Alchemy/Infura/dRPC/…) is strongly
# recommended for any deployment — the public default rate-limits under the
# registry multicall + judging traffic. Leave unset to use the public endpoint.
NEXT_PUBLIC_SEPOLIA_RPC=

# Public repository URL. When set, the "Add pair" modal shows a one-click
# "Suggest on GitHub" that opens a pre-filled issue. Leave unset to hide it.
# Example: https://github.com/your-org/suitz
NEXT_PUBLIC_REPO_URL=
